<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Update Cart</title>
    <link rel="stylesheet" href="/css/product.css"/>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"
            integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
    <script src="/js/product.js"></script>
</head>
<body>
<form id="addToCart">
    <input id="id" name="id" type="hidden" value=<%= id %>>
    <input id="productName" name="productName" type="hidden" value=<%= productName %> />
    <input id="price" name="price" type="hidden" value=<%= price %>>
    <h4>Product: <%= productName %></h4>
    <p><%= productName %></p>
    <h5>Price: <%= price %>/=</h5>
    <label for="quantity">Quantity</label>
    <input id="quantity" name="quantity" type="number" value='1'>
    <input type="submit" value="Add to Cart"> <span id="msg"></span>
</form>
<div>
    <h3>Items in cart</h3>
    <a href="/">Cart Items(<span id="cartSize"><%= cart_size ?? 0 %></span>)</a>
</div>
</body>
</html>
