<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Shopping List</title>
    <link rel="stylesheet" href="/css/product.css"/>
</head>
<body>
<h1>Products List</h1>

<%- include('products.ejs') %>

<table>
    <th>Name</th>
    <th>Price</th>
    <th>Quantity</th>
    <th>Action</th>
    <tbody>
    <% for (let id of Object.keys(products)) { %>
        <% product = products[id]; %>
        <tr>
            <td><%= product.name %></td>
            <td><%= product.price %></td>
            <td><%= product.quantity %></td>
            <td>
                <a href=<%= "/product?id=" + id %>>Update Cart</a>
            </td>
        </tr>
    <% } %>
    </tbody>
</table>
</body>
</html>